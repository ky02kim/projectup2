library(readxl)
library(dplyr)
library(stringr)
library(writexl)

df <- read_excel("원본.xlsx", sheet = "암의심")
exam_map <- read_excel("매핑.xlsx", sheet = "Sheet1")

df <- df %>%
  left_join(exam_map, by = c("검사명" = "원본값"))%>%
  mutate(검사명 = if_else(is.na(변경값), 검사명, 변경값))%>%
  select(-변경값)

company_map <-read_excel("매핑.xlsx", sheet = "Sheet2")
df <- df %/%
  left_join(company_map, by = c("거래처명" = "원본값"))


wirte_xlsx(df,"결과.xlsx")
