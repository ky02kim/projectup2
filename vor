# 발송항목 정의: (표시 이름, 레코드 필터 함수) — items는 1=뇌심, 2=직무, 3=감정노동, 4=건진데이터
CATEGORIES <- list(
  list(label = "사후관리소견서", cond = function(r) TRUE),
  list(label = "뇌심 · 직무",     cond = function(r) r$items[1] || r$items[2]),
  list(label = "뇌심",           cond = function(r) r$items[1]),
  list(label = "직무",           cond = function(r) r$items[2]),
  list(label = "감정노동",       cond = function(r) r$items[3]),
  list(label = "건진데이터",     cond = function(r) r$items[4])
)

fmt_period <- function(records) {
  if (length(records) == 0) return("")
  d1 <- as.Date(records[[1]]$periodStart); d2 <- as.Date(records[[1]]$periodEnd)
  sprintf("%d/%d~%d/%d", as.integer(format(d1, "%m")), as.integer(format(d1, "%d")),
          as.integer(format(d2, "%m")), as.integer(format(d2, "%d")))
}

# total(대상)은 status=='target', complete(완료)는 status=='complete' 레코드만 센다.
# 같은 사업장이 complete/target 두 줄로 각각 들어있는 구조를 전제로 함.
count_by_jongye <- function(records) {
  counts <- list(종건 = list(complete = 0, total = 0), 예건 = list(complete = 0, total = 0))
  for (r in records) {
    jy <- r$jongYe
    if (r$status == "target")   counts[[jy]]$total    <- counts[[jy]]$total + 1
    if (r$status == "complete") counts[[jy]]$complete <- counts[[jy]]$complete + 1
  }
  counts
}

# CATEGORIES 별로 종건/예건 완료·대상 건수를 집계해 표 행 리스트로 반환
aggregate_hgc <- function(records) {
  rows <- list()
  for (cat_def in CATEGORIES) {
    filtered <- Filter(cat_def$cond, records)
    counts <- count_by_jongye(filtered)
    has_complete <- any(vapply(filtered, function(r) r$status == "complete", logical(1)))

    lines <- c()
    for (jy in c("종건", "예건")) {
      c <- counts[[jy]]
      if (c$total == 0) next
      lines <- c(lines, if (c$complete == 0) sprintf("%s %d", jy, c$total)
                 else sprintf("%s %d/%d", jy, c$complete, c$total))
    }

    status <- if (length(filtered) == 0) "-" else if (has_complete) "발송완료" else "발송예정"
    period_txt <- fmt_period(filtered); if (period_txt == "") period_txt <- fmt_period(records)

    rows[[length(rows) + 1]] <- list(
      item = cat_def$label, period = period_txt,
      workplaces = if (length(lines) == 0) "-" else lines,
      status = status
    )
  }
  rows
}

group_by_period <- function(records) {
  groups <- list()
  for (r in records) {
    key <- paste(r$periodStart, r$periodEnd, sep = "|||")
    groups[[key]] <- c(groups[[key]], list(r))
  }
  groups
}

sheet_name_for <- function(period_start, period_end) {
  d1 <- as.Date(period_start); d2 <- as.Date(period_end)
  sprintf("%d.%d-%d.%d", as.integer(format(d1, "%m")), as.integer(format(d1, "%d")),
          as.integer(format(d2, "%m")), as.integer(format(d2, "%d")))
}

write_report_sheet <- function(wb, sheet, rows) {
  addWorksheet(wb, sheet)
  header_style <- createStyle(textDecoration = "bold", halign = "center", valign = "center",
                               border = "TopBottomLeftRight", fgFill = "D9D9D9")
  body_style <- createStyle(halign = "center", valign = "center", wrapText = TRUE,
                             border = "TopBottomLeftRight")

  headers <- c("발송항목", "대상 기간", "대상 사업장", "진행 상태")
  writeData(wb, sheet, t(headers), startRow = 1, colNames = FALSE)
  addStyle(wb, sheet, header_style, rows = 1, cols = 1:4, gridExpand = TRUE)

  r <- 2
  for (row in rows) {
    entries <- row$workplaces
    span <- length(entries)
    start_row <- r; end_row <- r + span - 1

    writeData(wb, sheet, row$item, startRow = start_row, startCol = 1, colNames = FALSE)
    writeData(wb, sheet, row$period, startRow = start_row, startCol = 2, colNames = FALSE)
    writeData(wb, sheet, row$status, startRow = start_row, startCol = 4, colNames = FALSE)
    if (span > 1) {
      mergeCells(wb, sheet, cols = 1, rows = start_row:end_row)
      mergeCells(wb, sheet, cols = 2, rows = start_row:end_row)
      mergeCells(wb, sheet, cols = 4, rows = start_row:end_row)
    }

    writeData(wb, sheet, entries, startRow = start_row, startCol = 3, colNames = FALSE)
    addStyle(wb, sheet, body_style, rows = start_row:end_row, cols = 1:4, gridExpand = TRUE)

    r <- end_row + 1
  }

  setColWidths(wb, sheet, cols = 1:4, widths = c(14, 16, 18, 14))
}

# 기간별로 시트를 나눠서 저장. 가장 최신 기간이 맨 앞 시트가 되도록 정렬
write_report_excel <- function(records, path) {
  groups <- group_by_period(records)
  keys <- names(groups)
  starts <- vapply(keys, function(k) strsplit(k, "\\|\\|\\|")[[1]][1], character(1))
  keys <- keys[order(starts, decreasing = TRUE)]

  wb <- createWorkbook()
  for (key in keys) {
    parts <- strsplit(key, "\\|\\|\\|")[[1]]
    rows <- aggregate_hgc(groups[[key]])
    write_report_sheet(wb, sheet_name_for(parts[1], parts[2]), rows)
  }
  saveWorkbook(wb, path, overwrite = TRUE)
  path
}

# ══════════════════════════════════════════════════════
#  메인
# ══════════════════════════════════════════════════════
main <- function() {
  base_dir <- getwd()
  output_dir <- file.path(base_dir, OUTPUT_DIR)
  dir.create(output_dir, showWarnings = FALSE)
  generated_at <- format(Sys.time(), "%Y-%m-%d %H:%M:%S")

  cat(strrep("=", 55), "\n", sep = "")
  cat("  기업건강의학센터 업무실적 - 엑셀 변환기 + 리포트 (R 통합본)\n")
  cat(strrep("=", 55), "\n", sep = "")

  # ── "업무 실적" 포함 파일 -> KNX / 자료요청서 ──
  knx_records <- list(); req_records <- list()
  excel_path <- find_file_by_name(base_dir, EXCEL_NAME_PATTERN)
  if (!is.null(excel_path)) {
    cat(sprintf("\n엑셀 파일 읽는 중... %s\n", basename(excel_path)))
    sheet_names <- tryCatch(openxlsx::getSheetNames(excel_path), error = function(e) character(0))
    cat(sprintf("       시트 목록: %s\n", paste(sheet_names, collapse = ", ")))

    if (length(sheet_names) >= 1) {
      raw1 <- read.xlsx(excel_path, sheet = 1, colNames = FALSE, skipEmptyRows = FALSE, detectDates = TRUE)
      knx_records <- parse_knx(raw1)
      cat(sprintf("       → KNX %d건 파싱 완료\n", length(knx_records)))
    }
    if (length(sheet_names) >= 2) {
      raw2 <- read.xlsx(excel_path, sheet = 2, colNames = FALSE, skipEmptyRows = FALSE, detectDates = TRUE)
      req_records <- parse_req(raw2)
      cat(sprintf("       → 자료요청서 %d건 파싱 완료\n", length(req_records)))
    }
  } else {
    cat(sprintf("\n'%s' 포함 파일이 없어 건너뜁니다.\n", EXCEL_NAME_PATTERN))
  }

  knx_df <- records_to_df(knx_records)   # items(0/1, 9개) + itemSum 포함
  req_df <- records_to_df(req_records)   # items(0/1, 9개) + itemSum 포함

  write_js(file.path(output_dir, "knx.js"), "KNX_DATA", knx_records, generated_at)
  write_js(file.path(output_dir, "req.js"), "REQ_DATA", req_records, generated_at)
  cat(sprintf("       ✓ data/knx.js  (%d건)\n", length(knx_records)))
  cat(sprintf("       ✓ data/req.js  (%d건)\n", length(req_records)))

  # ── "*사후관리*집계*.xlsx" -> 거래처별 사후관리 ──
  cat(sprintf("\n'%s' 패턴 파일 탐색 중...\n", HGC_NAME_REGEX))
  hgc_records <- process_hgc(base_dir)
  hgc_df <- records_to_df(hgc_records)   # items(TRUE/FALSE, 4개), itemSum 없음

  write_js(file.path(output_dir, "hgc.js"), "HGC_DATA", hgc_records, generated_at)
  cat(sprintf("       ✓ data/hgc.js  (%d개 기간 그룹)\n", length(hgc_records)))

  # ── 발송현황.xlsx 리포트 생성 (hgc_records 재사용, 별도 파일 재읽기 없음) ──
  report_path <- NULL
  if (length(hgc_records) > 0) {
    starts <- vapply(hgc_records, function(r) r$periodStart, character(1))
    latest_rec <- hgc_records[[order(starts, decreasing = TRUE)[1]]]
    d1 <- as.Date(latest_rec$periodStart); d2 <- as.Date(latest_rec$periodEnd)
    report_path <- file.path(base_dir, sprintf(
      "집계 %d.%d-%d.%d.xlsx",
      as.integer(format(d1, "%m")), as.integer(format(d1, "%d")),
      as.integer(format(d2, "%m")), as.integer(format(d2, "%d"))
    ))
    write_report_excel(hgc_records, report_path)
    cat(sprintf("       ✓ %s\n", basename(report_path)))
  } else {
    cat("       [정보] 사후관리 데이터가 없어 리포트를 생성하지 않았습니다.\n")
  }

  cat("\n", strrep("=", 55), "\n", sep = "")
  cat("  변환 완료!\n")
  cat(strrep("=", 55), "\n", sep = "")
  cat(sprintf("  KNX 발송      : %5d건\n", length(knx_records)))
  cat(sprintf("  자료요청서    : %5d건\n", length(req_records)))
  cat(sprintf("  사후관리 그룹 : %5d개\n", length(hgc_records)))

  invisible(list(knx_df = knx_df, req_df = req_df, hgc_df = hgc_df, report_path = report_path))
}

if (identical(environment(), globalenv())) {
  result <- main()
}
